     * meta-analysis of prediction model performance. BMJ, 356, i6460.
     * No transformation needed - calibration slope is approximately normal
     */
    function poolCalibrationSlopes(slopes, ses, method = 'REML') {
        const variances = ses.map(se => se * se);
        const result = randomEffects(slopes, variances, method);

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            ...result,
            pooledSlope: result.effect,
            slopeCI: result.ci,
            metric: 'Calibration Slope',
            interpretation: result.effect < 0.8 ? 'Overfitting likely' :
                           (result.effect > 1.2 ? 'Underfitting likely' : 'Acceptable calibration')
        };
    }

    /**
     * Pool O:E ratios using log transformation
     * Reference: Debray TPA et al. (2017). A guide to systematic review and
     * meta-analysis of prediction model performance. BMJ, 356, i6460.
     * Transform: log(O:E)
     */
    function poolOERatios(oeRatios, ses, method = 'REML') {
        // Transform to log scale
        const logOE = oeRatios.map(oe => Math.log(oe));
        const logSE = oeRatios.map((oe, i) => ses[i] / oe);
        const logVar = logSE.map(se => se * se);

        // Meta-analysis on log scale
        const result = randomEffects(logOE, logVar, method);

        // Back-transform
        const pooledOE = Math.exp(result.effect);
        const pooledLower = Math.exp(result.ci.lower);
        const pooledUpper = Math.exp(result.ci.upper);

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            ...result,
            pooledOE,
            oeCI: { lower: pooledLower, upper: pooledUpper },
            metric: 'O:E Ratio',
            interpretation: pooledOE < 0.8 ? 'Over-prediction' :
                           (pooledOE > 1.2 ? 'Under-prediction' : 'Acceptable calibration'),
            transformationNote: 'Analysis performed on log scale, back-transformed for interpretation'
        };
    }

    /**
     * Bivariate meta-analysis for sensitivity and specificity
     * Reference: Reitsma JB et al. (2005). Bivariate analysis of sensitivity and
     * specificity produces informative summary measures in diagnostic reviews.
     * Journal of Clinical Epidemiology, 58(10), 982-990.
     */
    function bivariateMetaAnalysis(sens, sensVar, spec, specVar, maxIter = 100) {
        const k = sens.length;

        // Transform using logit
        const logitSens = sens.map(s => Stats.logit(s));
        const logitSpec = spec.map(s => Stats.logit(s));

        // Variances on logit scale (protect against s=0 or s=1)
        const logitSensVar = sens.map((s, i) => {
            const denom = (s * (1 - s)) ** 2;
            return denom > 0 ? sensVar[i] / denom : sensVar[i] * 1e12;
        });
        const logitSpecVar = spec.map((s, i) => {
            const denom = (s * (1 - s)) ** 2;
            return denom > 0 ? specVar[i] / denom : specVar[i] * 1e12;
        });

        // Initial estimates
        let mu1 = Stats.mean(logitSens);
        let mu2 = Stats.mean(logitSpec);
        let tau2_1 = Stats.variance(logitSens);
        let tau2_2 = Stats.variance(logitSpec);
        let rho = 0;

        // Iterate EM-like algorithm
        for (let iter = 0; iter < maxIter; iter++) {
            const prevMu1 = mu1, prevMu2 = mu2;

            // E-step: compute weights
            const w1 = logitSensVar.map(v => 1 / (v + tau2_1));
            const w2 = logitSpecVar.map(v => 1 / (v + tau2_2));

            // M-step: update parameters
            mu1 = Stats.sum(logitSens.map((y, i) => w1[i] * y)) / Stats.sum(w1);
            mu2 = Stats.sum(logitSpec.map((y, i) => w2[i] * y)) / Stats.sum(w2);

            // Update tau²
            let ss1 = 0, ss2 = 0;
            for (let i = 0; i < k; i++) {
                ss1 += w1[i] * (logitSens[i] - mu1) ** 2;
                ss2 += w2[i] * (logitSpec[i] - mu2) ** 2;
            }

            tau2_1 = Math.max(0, (ss1 - (k - 1)) / Stats.sum(w1));
            tau2_2 = Math.max(0, (ss2 - (k - 1)) / Stats.sum(w2));

            // Update correlation
            let crossProd = 0;
            for (let i = 0; i < k; i++) {
                crossProd += Math.sqrt(w1[i] * w2[i]) * (logitSens[i] - mu1) * (logitSpec[i] - mu2);
            }
            const ssDenom = ss1 * ss2;
            rho = ssDenom > 0 ? crossProd / Math.sqrt(ssDenom) : 0;

            if (Math.abs(mu1 - prevMu1) < 1e-6 && Math.abs(mu2 - prevMu2) < 1e-6) break;
        }

        // Back-transform
        const pooledSens = Stats.invLogit(mu1);
        const pooledSpec = Stats.invLogit(mu2);

        // Standard errors
        const se1 = Math.sqrt(1 / Stats.sum(logitSensVar.map(v => 1 / (v + tau2_1))));
        const se2 = Math.sqrt(1 / Stats.sum(logitSpecVar.map(v => 1 / (v + tau2_2))));

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            sensitivity: pooledSens,
            specificity: pooledSpec,
            sensCI: {
                lower: Stats.invLogit(mu1 - 1.96 * se1),
                upper: Stats.invLogit(mu1 + 1.96 * se1)
            },
            specCI: {
                lower: Stats.invLogit(mu2 - 1.96 * se2),
                upper: Stats.invLogit(mu2 + 1.96 * se2)
            },
            tau2Sens: tau2_1,
            tau2Spec: tau2_2,
            correlation: rho,
            // Diagnostic accuracy measures (protect against extreme values)
            positiveLR: (1 - pooledSpec) > 0.001 ? pooledSens / (1 - pooledSpec) : Infinity,
            negativeLR: pooledSpec > 0.001 ? (1 - pooledSens) / pooledSpec : Infinity,
            diagnosticOR: ((1 - pooledSens) * (1 - pooledSpec)) > 0.001 ?
                (pooledSens * pooledSpec) / ((1 - pooledSens) * (1 - pooledSpec)) : Infinity
        };
    }

    // ============================================
    // Publication Bias Tests
    // ============================================

    /**
     * Egger's regression test
     * Reference: Egger M, Davey Smith G, Schneider M, Minder C. (1997).
     * Bias in meta-analysis detected by a simple, graphical test. BMJ, 315(7109), 629-634.
     * Formula: Regress standardized effect (yi/SEi) on precision (1/SEi)
     */
    function eggerTest(effects, ses) {
        const k = effects.length;
        const precision = ses.map(se => se > 0 ? 1 / se : 0);
        const standardized = effects.map((y, i) => ses[i] > 0 ? y / ses[i] : 0);

        // Weighted regression of standardized effect on precision
        const weights = ses.map(se => 1 / (se * se));
        const reg = Stats.weightedLinearRegression(precision, standardized, weights);

        const df = k - 2;
        const tValue = reg.intercept / reg.seIntercept;
        const pValue = 2 * (1 - Stats.pt(Math.abs(tValue), df));

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
