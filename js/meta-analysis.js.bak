    /**
     * Trim and fill method
     * Reference: Duval S, Tweedie R. (2000). Trim and fill: A simple funnel-plot-based
     * method of testing and adjusting for publication bias in meta-analysis.
     * Biometrics, 56(2), 455-463.
     */
    function trimAndFill(effects, variances, side = 'auto', estimator = 'L0') {
        const k = effects.length;

        // Initial pooled estimate
        let result = randomEffects(effects, variances, 'DL');
        const pooled0 = result.effect;

        // Determine side of funnel to trim
        const standardized = effects.map((y, i) =>
            variances[i] > 0 ? (y - pooled0) / Math.sqrt(variances[i]) : 0
        );

        // Count studies on each side
        const nRight = standardized.filter(z => z > 0).length;
        const nLeft = standardized.filter(z => z < 0).length;

        let trimSide;
        if (side === 'auto') {
            trimSide = nRight > nLeft ? 'right' : 'left';
        } else {
            trimSide = side;
        }

        // Iterative trimming
        let currentEffects = [...effects];
        let currentVariances = [...variances];
        let k0 = 0;  // Number of missing studies

        for (let iter = 0; iter < 50; iter++) {
            // Rank absolute deviations
            result = randomEffects(currentEffects, currentVariances, 'DL');
            const centered = currentEffects.map(y => y - result.effect);
            const absDevs = centered.map((d, i) => ({
                d,
                absDev: Math.abs(d),
                variance: currentVariances[i],
                index: i
            }));

            absDevs.sort((a, b) => a.absDev - b.absDev);

            // Calculate ranks
            const ranks = absDevs.map((_, i) => i + 1);

            // L0 estimator
            const signedRanks = absDevs.map((item, i) => {
                const sign = trimSide === 'right' ?
