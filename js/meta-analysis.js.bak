        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
 lower: Math.max(0, lower), upper: Math.max(0, upper) };
    }

    // ============================================
    // Fixed-Effect Meta-Analysis
    // ============================================

    /**
     * Inverse-variance fixed-effect meta-analysis
     * Reference: Hedges LV, Olkin I. (1985). Statistical Methods for Meta-Analysis.
     * Academic Press.
     * Formula: θ̂ = Σ(wi×yi) / Σwi, where wi = 1/vi
     */
    function fixedEffectIV(effects, variances) {
        const validation = validateInput(effects, variances);

        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        const pooledEffect = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;
        const pooledVariance = 1 / sumW;
        const pooledSE = Math.sqrt(pooledVariance);

        const zValue = pooledEffect / pooledSE;
        const pValue = 2 * (1 - Stats.pnorm(Math.abs(zValue)));

        const { Q, df, pValue: pHet } = calculateQ(effects, variances);

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            effect: pooledEffect,
            se: pooledSE,
            variance: pooledVariance,
            zValue,
            pValue,
            ci: {
                lower: pooledEffect - 1.96 * pooledSE,
                upper: pooledEffect + 1.96 * pooledSE
            },
            weights: weights.map(w => 100 * w / sumW),
            Q, df, pHet,
            method: 'Fixed-Effect (Inverse Variance)',
            warnings: validation.warnings
        };
    }

    /**
     * Mantel-Haenszel meta-analysis for binary outcomes
     * Reference: Mantel N, Haenszel W. (1959). Statistical aspects of the analysis
     * of data from retrospective studies of disease.
     * Journal of the National Cancer Institute, 22(4), 719-748.
     *
     * Variance: Robins-Breslow-Greenland method
     * Reference: Robins J, Breslow N, Greenland S. (1986). Estimators of the
     * Mantel-Haenszel variance consistent in both sparse data and large-strata
     * limiting models. Biometrics, 42(2), 311-323.
     */
    function fixedEffectMH(a, b, c, d) {
        // a = events treatment, b = non-events treatment
        // c = events control, d = non-events control
        const k = a.length;
        const n = a.map((ai, i) => ai + b[i] + c[i] + d[i]);

        // For OR
        let sumAD_n = 0, sumBC_n = 0;
        let sumR = 0, sumS = 0, sumRS = 0;

        for (let i = 0; i < k; i++) {
            const ni = n[i];
            const ai_val = a[i], bi = b[i], ci = c[i], di = d[i];

            sumAD_n += ai_val * di / ni;
            sumBC_n += bi * ci / ni;

            const R = ai_val * di / ni;
            const S = bi * ci / ni;
            sumR += R;
            sumS += S;
            sumRS += (ai_val + di) * R / ni + (bi + ci) * S / ni;
        }

        const orMH = sumBC_n > 0 ? sumAD_n / sumBC_n : 1;
        const logOR = orMH > 0 ? Math.log(orMH) : 0;

        // Robins-Breslow-Greenland variance
        let P = 0, Q = 0, R = 0;
        for (let i = 0; i < k; i++) {
            const ni = n[i];
            const ai_val = a[i], bi = b[i], ci = c[i], di = d[i];

            P += (ai_val + di) * ai_val * di / (ni * ni);
            Q += ((ai_val + di) * bi * ci + (bi + ci) * ai_val * di) / (ni * ni);
            R += (bi + ci) * bi * ci / (ni * ni);
        }

        const denom1 = 2 * sumAD_n * sumAD_n;
        const denom2 = 2 * sumAD_n * sumBC_n;
        const denom3 = 2 * sumBC_n * sumBC_n;
        const variance = (denom1 > 0 ? P / denom1 : 0) +
                        (denom2 > 0 ? Q / denom2 : 0) +
                        (denom3 > 0 ? R / denom3 : 0);

        const se = Math.sqrt(variance);
        const zValue = logOR / se;
        const pValue = 2 * (1 - Stats.pnorm(Math.abs(zValue)));

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            effect: logOR,
            se,
            variance,
            or: orMH,
            zValue,
            pValue,
            ci: {
                lower: logOR - 1.96 * se,
                upper: logOR + 1.96 * se
            },
            orCI: {
                lower: Math.exp(logOR - 1.96 * se),
                upper: Math.exp(logOR + 1.96 * se)
            },
            method: 'Mantel-Haenszel'
        };
    }

    /**
     * Peto method for rare events
     * Reference: Yusuf S, Peto R, Lewis J, Collins R, Sleight P. (1985).
     * Beta blockade during and after myocardial infarction: an overview of the
     * randomized trials. Progress in Cardiovascular Diseases, 27(5), 335-371.
     * Formula: log(OR) = Σ(Oi - Ei) / ΣVi
     */
    function fixedEffectPeto(a, b, c, d) {
        const k = a.length;

        let sumOE = 0;
        let sumV = 0;

        for (let i = 0; i < k; i++) {
            const ai_val = a[i], bi = b[i], ci = c[i], di = d[i];
            const n1i = ai_val + bi;
            const n2i = ci + di;
            const ni = n1i + n2i;
            const mi = ai_val + ci;

            const Ei = ni > 0 ? n1i * mi / ni : 0;
            const niDenom = ni * ni * Math.max(1, ni - 1);
            const Vi = niDenom > 0 ? n1i * n2i * mi * (ni - mi) / niDenom : 0;

            sumOE += ai_val - Ei;
            sumV += Vi;
        }

        const logOR = sumV > 0 ? sumOE / sumV : 0;
        const se = sumV > 0 ? 1 / Math.sqrt(sumV) : Infinity;
        const zValue = sumOE / Math.sqrt(sumV);
        const pValue = 2 * (1 - Stats.pnorm(Math.abs(zValue)));

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            effect: logOR,
            se,
            variance: 1 / sumV,
            or: Math.exp(logOR),
            zValue,
            pValue,
            ci: {
                lower: logOR - 1.96 * se,
                upper: logOR + 1.96 * se
            },
            orCI: {
                lower: Math.exp(logOR - 1.96 * se),
                upper: Math.exp(logOR + 1.96 * se)
            },
            method: 'Peto'
        };
    }

    // ============================================
    // Random-Effects Meta-Analysis
    // ============================================

    /**
     * Standard random-effects meta-analysis
     * Reference: DerSimonian R, Laird N. (1986). Meta-analysis in clinical trials.
     * Controlled Clinical Trials, 7(3), 177-188.
     *
     * Prediction interval formula from:
     * Reference: Riley RD, Higgins JPT, Deeks JJ. (2011). Interpretation of
     * random effects meta-analyses. BMJ, 342, d549.
     */
    function randomEffects(effects, variances, tau2Method = 'DL') {
        const validation = validateInput(effects, variances);
        const k = effects.length;

        // Get tau² estimator
        const estimator = getTau2Estimator(tau2Method);
        const tau2Result = estimator(effects, variances, { diagnostics: true });

        // Handle both simple returns and diagnostic objects
        const tau2 = typeof tau2Result === 'object' && tau2Result.estimate !== undefined
            ? tau2Result.estimate
            : tau2Result;

        const convergenceInfo = typeof tau2Result === 'object' ? {
            converged: tau2Result.converged,
            iterations: tau2Result.iterations,
            convergenceWarning: tau2Result.warning
        } : { converged: true, iterations: 1 };

        // Random effects weights
        const weights = variances.map(v => 1 / (v + tau2));
        const sumW = Stats.sum(weights);

        // Pooled effect
        const pooledEffect = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;
        const pooledVariance = 1 / sumW;
        const pooledSE = Math.sqrt(pooledVariance);

        // Test statistic
        const zValue = pooledEffect / pooledSE;
        const pValue = 2 * (1 - Stats.pnorm(Math.abs(zValue)));

        // Confidence interval
        const ci = {
            lower: pooledEffect - 1.96 * pooledSE,
            upper: pooledEffect + 1.96 * pooledSE
        };

        // Prediction interval (Riley et al. 2011)
        // Uses t-distribution with k-2 df
        const tCrit = Stats.qt(0.975, Math.max(1, k - 2));
        const piVar = pooledVariance + tau2;
        const predictionInterval = {
            lower: pooledEffect - tCrit * Math.sqrt(piVar),
            upper: pooledEffect + tCrit * Math.sqrt(piVar)
