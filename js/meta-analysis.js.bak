    return {
            coefficients,
            intercept: coefficients[0],
            moderators: coefficients.slice(1),
            tau2,
            tau2Null,
            R2: Math.max(0, R2),
            QM,
            dfM,
            pQM,
            QE,
            dfE: k - p - 1,
            I2Residual: I2Res,
            knhaApplied: knha,
            method
