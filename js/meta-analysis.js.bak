    /**
     * Hartung-Knapp-Sidik-Jonkman adjustment
     * Reference: Hartung J, Knapp G. (2001). On tests of the overall treatment
     * effect in meta-analysis with normally distributed responses.
     * Statistics in Medicine, 20(12), 1771-1782.
     *
     * Also: IntHout J, Ioannidis JP, Borm GF. (2014). The Hartung-Knapp-Sidik-Jonkman
     * method for random effects meta-analysis is straightforward and considerably
     * outperforms the standard DerSimonian-Laird method.
     * BMC Medical Research Methodology, 14, 25.
     *
     * @param {boolean} truncate - If true, apply q ≥ 1 truncation (default: true)
     *   Note: IntHout et al. (2014) recommend truncation as HKSJ can produce
     *   narrower CIs than standard when q < 1
     */
    function randomEffectsHKSJ(effects, variances, tau2Method = 'DL', options = {}) {
        const truncate = options.truncate !== undefined ? options.truncate : CONFIG.hksj.truncate;

        const result = randomEffects(effects, variances, tau2Method);
        const k = effects.length;

        // HKSJ adjustment factor
        const weights = variances.map(v => 1 / (v + result.tau2));
        const sumW = Stats.sum(weights);

        let qStar = 0;
        for (let i = 0; i < k; i++) {
            qStar += weights[i] * Math.pow(effects[i] - result.effect, 2);
        }

        let adjFactor = qStar / (k - 1);

        // Apply truncation if enabled (IntHout et al. 2014 recommendation)
        const originalAdjFactor = adjFactor;
        if (truncate && adjFactor < CONFIG.hksj.minQ) {
            adjFactor = CONFIG.hksj.minQ;
        }

        // Adjusted SE
        const adjustedSE = result.se * Math.sqrt(adjFactor);

        // Use t-distribution with k-1 df
        const tCrit = Stats.qt(0.975, k - 1);
        const tValue = result.effect / adjustedSE;
        const pValue = 2 * (1 - Stats.pt(Math.abs(tValue), k - 1));

        // Add warning if truncation was applied
        const warnings = [...(result.warnings || [])];
        if (truncate && originalAdjFactor < CONFIG.hksj.minQ) {
            warnings.push(`HKSJ adjustment factor (q=${originalAdjFactor.toFixed(4)}) was < 1 and truncated to 1.0 (IntHout et al. 2014)`);
        }

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            ...result,
            se: adjustedSE,
            variance: adjustedSE * adjustedSE,
            tValue,
            zValue: tValue,  // For compatibility
            pValue,
            ci: {
                lower: result.effect - tCrit * adjustedSE,
                upper: result.effect + tCrit * adjustedSE
            },
            hksjAdjustment: adjFactor,
            hksjOriginalAdjustment: originalAdjFactor,
            hksjTruncated: truncate && originalAdjFactor < CONFIG.hksj.minQ,
            df: k - 1,
            method: `Random-Effects (${tau2Method} + HKSJ${truncate ? ', truncated' : ''})`,
            warnings
        };
    }

    /**
     * Compare confidence interval methods
     * Compares standard (Wald z-based), HKSJ, and HKSJ-truncated
     */
    function compareConfidenceIntervals(effects, variances, tau2Method = 'DL') {
        const standard = randomEffects(effects, variances, tau2Method);
        const hksjNoTrunc = randomEffectsHKSJ(effects, variances, tau2Method, { truncate: false });
        const hksjTrunc = randomEffectsHKSJ(effects, variances, tau2Method, { truncate: true });

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            pooledEffect: standard.effect,
            methods: {
                'Wald (z-based)': {
                    ci: standard.ci,
                    se: standard.se,
                    width: standard.ci.upper - standard.ci.lower,
                    pValue: standard.pValue
                },
                'HKSJ (no truncation)': {
                    ci: hksjNoTrunc.ci,
                    se: hksjNoTrunc.se,
                    width: hksjNoTrunc.ci.upper - hksjNoTrunc.ci.lower,
                    pValue: hksjNoTrunc.pValue,
                    adjFactor: hksjNoTrunc.hksjOriginalAdjustment,
                    df: hksjNoTrunc.df
                },
                'HKSJ (truncated q≥1)': {
                    ci: hksjTrunc.ci,
                    se: hksjTrunc.se,
                    width: hksjTrunc.ci.upper - hksjTrunc.ci.lower,
                    pValue: hksjTrunc.pValue,
                    adjFactor: hksjTrunc.hksjAdjustment,
                    truncated: hksjTrunc.hksjTruncated,
                    df: hksjTrunc.df
                }
            },
            recommendation: hksjNoTrunc.hksjOriginalAdjustment < 1 ?
                'HKSJ with truncation recommended (q < 1 would narrow CI)' :
                'All methods produce similar results'
        };
    }

    // ============================================
    // Prediction Model Metrics
    // ============================================

    /**
     * Pool C-statistics using logit transformation
     * Reference: Debray TPA et al. (2017). A guide to systematic review and
     * meta-analysis of prediction model performance. BMJ, 356, i6460.
     * Transform: logit(C) = ln(C/(1-C))
     * SE on logit scale: SE/(C×(1-C)) via delta method
     */
    function poolCStatistics(cstats, ses, method = 'REML') {
        // Transform to logit scale
        const logitC = cstats.map(c => Stats.logit(c));

        // SE on logit scale: delta method (protect against c=0 or c=1)
        const logitSE = cstats.map((c, i) => {
            const denom = c * (1 - c);
            return denom > 0 ? ses[i] / denom : ses[i] * 1e6;
        });
        const logitVar = logitSE.map(se => se * se);

        // Run meta-analysis on logit scale
        const result = randomEffects(logitC, logitVar, method);

        // Back-transform
        const pooledC = Stats.invLogit(result.effect);
        const pooledLower = Stats.invLogit(result.ci.lower);
        const pooledUpper = Stats.invLogit(result.ci.upper);

        const piLower = Stats.invLogit(result.predictionInterval.lower);
        const piUpper = Stats.invLogit(result.predictionInterval.upper);

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            ...result,
            pooledC,
            cCI: { lower: pooledLower, upper: pooledUpper },
            cPredictionInterval: { lower: piLower, upper: piUpper },
            metric: 'C-statistic',
            transformationNote: 'Analysis performed on logit scale, back-transformed for interpretation'
