                    .filter(item => trimSide === 'right' ? item.d > 0 : item.d < 0)
                    .slice(-k0)
                    .map(item => item.index);

                currentEffects = effects.filter((_, i) => !toRemove.includes(i));
                currentVariances = variances.filter((_, i) => !toRemove.includes(i));
