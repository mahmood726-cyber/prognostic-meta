            const T = Stats.sum(signedRanks.filter(r => r > 0));
            const n = currentEffects.length;
            const k0New = Math.round(Math.max(0, (4 * T - n * (n + 1)) / (2 * n + 1)));

            if (k0New === k0) break;
            k0 = k0New;

            // Trim the most extreme studies
            if (k0 > 0) {
