/**
 * PrognosisMeta - Core Meta-Analysis Module
 * Comprehensive meta-analysis methods exceeding R packages
 * Supports prognostic factors and prediction model metrics
 *
 * Editorial Revisions: December 2024
 * - Added convergence diagnostics to all iterative estimators
 * - Added formula references with citations
 * - Implemented HKSJ with q≥1 truncation option (IntHout et al. 2014)
 * - Added method comparison features
 * - Added input validation and edge case warnings
 */

const MetaAnalysis = (function() {
    'use strict';

    if (typeof Statistics === 'undefined') {
        throw new Error('Statistics module must be loaded before MetaAnalysis');
    }
    const Stats = Statistics;

    // ============================================
    // Configuration and Thresholds
    // ============================================

    const CONFIG = {
        convergence: {
            maxIter: 1000,
            tolerance: 1e-8,
            warningThreshold: 100
        },
        warnings: {
            minStudies: 5,           // Warn if k < 5
            highHeterogeneity: 75,   // Warn if I² > 75%
            extremeHeterogeneity: 95 // Strong warning if I² > 95%
        },
        hksj: {
            truncate: true,          // Default: apply q ≥ 1 truncation
            minQ: 1.0                // Minimum q value when truncation enabled
        }
    };

    // ============================================
    // Input Validation and Warnings
    // ============================================

    /**
     * Validate meta-analysis inputs and generate warnings
     * @param {Array} effects - Effect sizes
     * @param {Array} variances - Variances
     * @returns {Object} Validation result with warnings
     */
    function validateInput(effects, variances) {
        const warnings = [];
        const errors = [];
        const k = effects.length;

        // Check array lengths match
        if (effects.length !== variances.length) {
            errors.push('Effect sizes and variances arrays must have same length');
        }

        // Check minimum studies
        if (k < 2) {
            errors.push('Meta-analysis requires at least 2 studies');
        } else if (k < CONFIG.warnings.minStudies) {
            warnings.push(`Small number of studies (k=${k}). Results may be unstable.`);
        }

        // Check for single study
        if (k === 1) {
            warnings.push('Single study: Cannot estimate between-study variance');
        }

        // Check for invalid values
        const hasNaN = effects.some(e => isNaN(e)) || variances.some(v => isNaN(v));
        const hasInfinite = effects.some(e => !isFinite(e)) || variances.some(v => !isFinite(v));
        const hasZeroVar = variances.some(v => v <= 0);

        if (hasNaN) errors.push('Data contains NaN values');
        if (hasInfinite) errors.push('Data contains infinite values');
        if (hasZeroVar) errors.push('Variances must be positive (> 0)');

        // Check for homogeneity
        const varOfEffects = Stats.variance(effects);
        if (varOfEffects < 1e-10) {
            warnings.push('Effect sizes appear homogeneous - tau² will be 0');
        }

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            valid: errors.length === 0,
            errors,
            warnings,
            k
        };
    }

    // ============================================
    // Heterogeneity Estimators (τ²)
    // ============================================

    /**
     * Calculate Q-statistic (Cochran's Q)
     * Reference: Cochran WG. (1954). The combination of estimates from
     * different experiments. Biometrics, 10(1), 101-129.
     * Formula: Q = Σ wi(yi - ȳ)²
     */
    function calculateQ(effects, variances) {
        const k = effects.length;
        if (k === 0) return {
 Q: 0, df: 0, pValue: 1 };

        const weights = variances.map(v => v > 0 ? 1 / v : 0);
        const sumW = Stats.sum(weights);
        if (sumW === 0) return {
 Q: 0, df: Math.max(0, k - 1), pValue: 1 };

        const sumWY = effects.reduce((s, y, i) => s + weights[i] * y, 0);
        const yBar = sumWY / sumW;

        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - yBar, 2), 0);
        const df = Math.max(0, k - 1);
        const pValue = df > 0 ? 1 - Stats.pchisq(Q, df) : 1;

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
 Q, df, pValue };
    }

    /**
     * DerSimonian-Laird estimator
     * Reference: DerSimonian R, Laird N. (1986). Meta-analysis in clinical trials.
     * Controlled Clinical Trials, 7(3), 177-188.
     * Formula: τ² = max(0, (Q - df) / C) where C = Σwi - Σwi²/Σwi
     */
    function tau2DL(effects, variances) {
        const k = effects.length;
        if (k < 2) return 0;

        const weights = variances.map(v => v > 0 ? 1 / v : 0);
        const sumW = Stats.sum(weights);
        if (sumW === 0) return 0;

        const sumW2 = Stats.sum(weights.map(w => w * w));

        const { Q, df } = calculateQ(effects, variances);
        const C = sumW - sumW2 / sumW;

        const tau2 = C > 0 ? Math.max(0, (Q - df) / C) : 0;

        return tau2;
    }

    /**
     * Paule-Mandel estimator (iterative)
     * Reference: Paule RC, Mandel J. (1982). Consensus values and weighting factors.
     * Journal of Research of the National Bureau of Standards, 87(5), 377-385.
     * Formula: Iteratively solve Q*(τ²) = k - 1
     * @returns {Object} tau2 estimate with convergence diagnostics
     */
    function tau2PM(effects, variances, options = {}) {
        const maxIter = options.maxIter || CONFIG.convergence.maxIter;
        const tol = options.tolerance || CONFIG.convergence.tolerance;
        const returnDiagnostics = options.diagnostics !== false;

        const k = effects.length;
        let tau2 = tau2DL(effects, variances);
        let converged = false;
        let iterations = 0;

        for (let iter = 0; iter < maxIter; iter++) {
            iterations = iter + 1;
            const weights = variances.map(v => 1 / (v + tau2));
            const sumW = Stats.sum(weights);
            const yBar = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

            const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - yBar, 2), 0);

            // PM iteration: Q should equal k-1
            const Qstar = k - 1;

            if (Q <= Qstar) {
                tau2 = 0;
                converged = true;
                break;
            }

            // Newton-Raphson step
            const dQ = -effects.reduce((s, y, i) => {
                const w = weights[i];
                return s + w * w * Math.pow(y - yBar, 2);
            }, 0);

            const tau2New = Math.abs(dQ) > 1e-12 ? tau2 + (Q - Qstar) / (-dQ) : tau2;

            if (Math.abs(tau2New - tau2) < tol) {
                tau2 = Math.max(0, tau2New);
                converged = true;
                break;
            }

            tau2 = Math.max(0, tau2New);
        }

        if (returnDiagnostics) {
        
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
                estimate: tau2,
                converged,
                iterations,
                method: 'Paule-Mandel',
                warning: !converged ? `Did not converge in ${maxIter} iterations` : null
            };
        }

        return tau2;
    }

    /**
     * Maximum Likelihood estimator
     * Reference: Hardy RJ, Thompson SG. (1996). A likelihood approach to
     * meta-analysis with random effects. Statistics in Medicine, 15(6), 619-629.
     * Formula: Maximize L(μ, τ²) = -0.5 Σ[log(vi + τ²) + (yi - μ)²/(vi + τ²)]
     * @returns {Object} tau2 estimate with convergence diagnostics
     */
    function tau2ML(effects, variances, options = {}) {
        const maxIter = options.maxIter || CONFIG.convergence.maxIter;
        const tol = options.tolerance || CONFIG.convergence.tolerance;
        const returnDiagnostics = options.diagnostics !== false;

        const k = effects.length;
        let tau2 = tau2DL(effects, variances);
        let converged = false;
        let iterations = 0;

        for (let iter = 0; iter < maxIter; iter++) {
            iterations = iter + 1;
            const weights = variances.map(v => 1 / (v + tau2));
            const sumW = Stats.sum(weights);
            const yBar = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

            // Score function U and Fisher information I
            let U = 0;
            let I = 0;

            for (let i = 0; i < k; i++) {
                const v = variances[i] + tau2;
                const resid2 = Math.pow(effects[i] - yBar, 2);
                U += (resid2 - v) / (v * v);
                I += 1 / (v * v);
            }

            U *= 0.5;
            I *= 0.5;

            if (Math.abs(U) < tol) {
                converged = true;
                break;
            }

            const tau2New = Math.abs(I) > 1e-12 ? tau2 + U / I : tau2;

            if (Math.abs(tau2New - tau2) < tol) {
                tau2 = Math.max(0, tau2New);
                converged = true;
                break;
            }

            tau2 = Math.max(0, tau2New);
        }

        if (returnDiagnostics) {
        
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
                estimate: tau2,
                converged,
                iterations,
                method: 'Maximum Likelihood',
                warning: !converged ? `Did not converge in ${maxIter} iterations` : null
            };
        }

        return tau2;
    }

    /**
     * Restricted Maximum Likelihood (REML) estimator
     * Reference: Viechtbauer W. (2005). Bias and efficiency of meta-analytic
     * variance estimators in the random-effects model.
     * Journal of Educational and Behavioral Statistics, 30(3), 261-293.
     * Formula: Maximize restricted log-likelihood with adjustment for μ estimation
     * @returns {Object} tau2 estimate with convergence diagnostics
     */
    function tau2REML(effects, variances, options = {}) {
        const maxIter = options.maxIter || CONFIG.convergence.maxIter;
        const tol = options.tolerance || CONFIG.convergence.tolerance;
        const returnDiagnostics = options.diagnostics !== false;

        const k = effects.length;
        let tau2 = tau2DL(effects, variances);
        let converged = false;
        let iterations = 0;

        for (let iter = 0; iter < maxIter; iter++) {
            iterations = iter + 1;
            const weights = variances.map(v => 1 / (v + tau2));
            const sumW = Stats.sum(weights);
            const sumW2 = Stats.sum(weights.map(w => w * w));
            const yBar = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

            // REML score function
            let U = 0;
            for (let i = 0; i < k; i++) {
                const v = variances[i] + tau2;
                const resid2 = Math.pow(effects[i] - yBar, 2);
                U += (resid2 - v) / (v * v);
            }
            U = 0.5 * U + 0.5 * sumW2 / sumW;

            // Fisher information
            let I = 0;
            for (let i = 0; i < k; i++) {
                const v = variances[i] + tau2;
                I += 1 / (v * v);
            }
            I = 0.5 * I - 0.5 * sumW2 * sumW2 / (sumW * sumW);

            if (Math.abs(U) < tol || Math.abs(I) < tol) {
                converged = true;
                break;
            }

            const tau2New = Math.abs(I) > 1e-12 ? tau2 + U / I : tau2;

            if (Math.abs(tau2New - tau2) < tol) {
                tau2 = Math.max(0, tau2New);
                converged = true;
                break;
            }

            tau2 = Math.max(0, tau2New);
        }

        if (returnDiagnostics) {
        
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
                estimate: tau2,
                converged,
                iterations,
                method: 'REML',
                warning: !converged ? `Did not converge in ${maxIter} iterations` : null
            };
        }

        return tau2;
    }

    /**
     * Hunter-Schmidt estimator
     * Reference: Hunter JE, Schmidt FL. (2004). Methods of Meta-Analysis:
     * Correcting Error and Bias in Research Findings. Sage Publications.
     * Formula: τ² = max(0, Var(yi) - E(vi))
     */
    function tau2HS(effects, variances) {
        const k = effects.length;
        if (k < 2) return 0;

        const weights = variances.map(v => v > 0 ? 1 / v : 0);
        const sumW = Stats.sum(weights);
        if (sumW === 0) return 0;

        const yBar = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        const varY = effects.reduce((s, y, i) => {
            return s + weights[i] * Math.pow(y - yBar, 2);
        }, 0) / sumW;

        const meanVar = k / sumW;

        return Math.max(0, varY - meanVar);
    }

    /**
     * Sidik-Jonkman estimator
     * Reference: Sidik K, Jonkman JN. (2005). Simple heterogeneity variance
     * estimation for meta-analysis. Journal of the Royal Statistical Society:
     * Series C (Applied Statistics), 54(2), 367-384.
     * Formula: Iterative τ² = τ²(prev) × Q* / (k-1)
     * @returns {Object} tau2 estimate with convergence diagnostics
     */
    function tau2SJ(effects, variances, options = {}) {
        const maxIter = options.maxIter || CONFIG.convergence.maxIter;
        const tol = options.tolerance || CONFIG.convergence.tolerance;
