    }

    /**
     * Cumulative meta-analysis
     * Reference: Lau J, Antman EM, Jimenez-Silva J, Kupelnick B, Mosteller F,
     * Chalmers TC. (1992). Cumulative meta-analysis of therapeutic trials for
     * myocardial infarction. New England Journal of Medicine, 327(4), 248-254.
     */
    function cumulativeMetaAnalysis(effects, variances, studyNames, sortBy = 'year', tau2Method = 'DL') {
        const k = effects.length;
        const results = [];

        // Sort indices (assuming studyNames contains years or order info)
        const indices = Array.from({ length: k }, (_, i) => i);
        // For now, use original order

        let cumEffects = [];
        let cumVariances = [];
        let cumNames = [];

        for (let i = 0; i < k; i++) {
            cumEffects.push(effects[indices[i]]);
            cumVariances.push(variances[indices[i]]);
            cumNames.push(studyNames[indices[i]]);

            const result = randomEffects(cumEffects, cumVariances, tau2Method);

            results.push({
                study: cumNames[i],
                k: i + 1,
                effect: result.effect,
                se: result.se,
                ci: result.ci,
                I2: result.I2
            });
        }

        return results;
    }

    /**
     * Influence diagnostics (Cook's distance, etc.)
     * Reference: Viechtbauer W, Cheung MW. (2010). Outlier and influence
     * diagnostics for meta-analysis. Research Synthesis Methods, 1(2), 112-125.
     */
    function influenceDiagnostics(effects, variances, tau2Method = 'DL') {
        const k = effects.length;
        const overall = randomEffects(effects, variances, tau2Method);

        const loo = leaveOneOut(effects, variances,
            Array.from({ length: k }, (_, i) => `Study ${i + 1}`), tau2Method);

        const diagnostics = [];

        for (let i = 0; i < k; i++) {
            const weight = 1 / (variances[i] + overall.tau2);
            const sumW = variances.reduce((s, v) => s + 1 / (v + overall.tau2), 0);
            const leverage = weight / sumW;

            const residual = effects[i] - overall.effect;
            const standardizedResidual = residual / Math.sqrt(variances[i] + overall.tau2);

            // Cook's distance analog
            const cooksD = Math.pow(overall.effect - loo.results[i].effect, 2) /
                          (overall.variance * 2);

            // DFFITS analog
            const dffits = (overall.effect - loo.results[i].effect) /
                          Math.sqrt(overall.variance * leverage);

            diagnostics.push({
                study: i + 1,
                weight: 100 * weight / sumW,
                leverage,
                residual,
                standardizedResidual,
                cooksD,
                dffits,
                influential: Math.abs(standardizedResidual) > 2 || cooksD > 4 / k
            });
        }

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
