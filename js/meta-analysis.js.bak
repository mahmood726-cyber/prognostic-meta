    // ============================================
    // Sensitivity Analysis
    // Reference: Viechtbauer W, Cheung MW. (2010). Outlier and influence
    // diagnostics for meta-analysis. Research Synthesis Methods, 1(2), 112-125.
    // ============================================

    /**
     * Leave-one-out sensitivity analysis
     * Recalculates pooled effect removing each study in turn
     * @param {Array} effects - Effect sizes
     * @param {Array} variances - Variances
     * @param {Object} options - Analysis options
     * @returns {Object} Leave-one-out results with influence statistics
     */
    function leaveOneOut(effects, variances, options = {}) {
        const k = effects.length;
        const method = options.method || 'REML';
        const results = [];

        // Get full analysis for comparison
        const fullResult = randomEffects(effects, variances, { method });

        for (let i = 0; i < k; i++) {
            // Remove study i
            const subEffects = effects.filter((_, j) => j !== i);
            const subVariances = variances.filter((_, j) => j !== i);

            if (subEffects.length < 2) continue;

            const subResult = randomEffects(subEffects, subVariances, { method });

            // Calculate influence statistics
            const diffEffect = fullResult.estimate - subResult.estimate;
            const dfbetas = diffEffect / fullResult.se;

            results.push({
                omitted: i,
                estimate: subResult.estimate,
                se: subResult.se,
                ci: subResult.ci,
                tau2: subResult.tau2,
                I2: subResult.I2,
                diffEffect: diffEffect,
                dfbetas: dfbetas,
                influential: Math.abs(dfbetas) > 2 / Math.sqrt(k)
            });
        }

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            full: fullResult,
            leaveOneOut: results,
            influentialStudies: results.filter(r => r.influential).map(r => r.omitted)
        };
    }

    /**
     * Cumulative meta-analysis
     * Shows how pooled estimate changes as studies are added
     * @param {Array} effects - Effect sizes
     * @param {Array} variances - Variances
     * @param {Array} order - Order to add studies (default: by year/index)
     * @param {Object} options - Analysis options
     */
    function cumulativeMetaAnalysis(effects, variances, order = null, options = {}) {
        const k = effects.length;
        const method = options.method || 'DL';

        // Default order is original order
        if (!order) order = [...Array(k).keys()];

        const results = [];

        for (let i = 0; i < k; i++) {
            const indices = order.slice(0, i + 1);
            const subEffects = indices.map(j => effects[j]);
            const subVariances = indices.map(j => variances[j]);

            if (subEffects.length < 2) {
                // Single study
                results.push({
                    k: 1,
                    estimate: subEffects[0],
                    se: Math.sqrt(subVariances[0]),
                    ci: [
                        subEffects[0] - 1.96 * Math.sqrt(subVariances[0]),
                        subEffects[0] + 1.96 * Math.sqrt(subVariances[0])
                    ],
                    tau2: 0,
                    I2: 0
                });
            } else {
                const result = randomEffects(subEffects, subVariances, { method });
                results.push({
                    k: subEffects.length,
                    estimate: result.estimate,
                    se: result.se,
                    ci: result.ci,
                    tau2: result.tau2,
                    I2: result.I2
                });
            }
        }

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            cumulative: results,
            order: order
        };
    }

    /**
     * Influence diagnostics (Cook's distance, DFBETAS, etc.)
     * Reference: Viechtbauer W. (2021). Model checking in meta-analysis.
     * In: Handbook of Meta-Analysis. CRC Press.
     */
    function influenceDiagnostics(effects, variances, options = {}) {
        const k = effects.length;
        const method = options.method || 'REML';

        const fullResult = randomEffects(effects, variances, { method });
        const weights = variances.map(v => 1 / (v + fullResult.tau2));
        const sumW = Stats.sum(weights);

        const diagnostics = [];

        for (let i = 0; i < k; i++) {
            const w = weights[i];
            const resid = effects[i] - fullResult.estimate;
            const vi = variances[i] + fullResult.tau2;

            // Standardized residual
            const stdResid = resid / Math.sqrt(vi);

            // Studentized residual (leave-one-out)
            const subEffects = effects.filter((_, j) => j !== i);
            const subVariances = variances.filter((_, j) => j !== i);
            const subResult = subEffects.length >= 2 ?
                randomEffects(subEffects, subVariances, { method }) : null;

            const studentResid = subResult ?
                resid / Math.sqrt(variances[i] + subResult.tau2) : stdResid;

            // Hat value (leverage)
            const hat = w / sumW;

            // Cook's distance analog
            const cookD = (w * resid * resid) / (vi * sumW);

            // DFFITS
            const dffits = stdResid * Math.sqrt(hat / (1 - hat));

            // Covariance ratio
            const covRatio = subResult ?
                (subResult.se * subResult.se) / (fullResult.se * fullResult.se) : 1;

            diagnostics.push({
                study: i,
                residual: resid,
                stdResid: stdResid,
                studentResid: studentResid,
                hat: hat,
                cookD: cookD,
                dffits: dffits,
                covRatio: covRatio,
                influential: Math.abs(studentResid) > 2 || cookD > 4 / k
            });
        }

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            diagnostics: diagnostics,
            outliers: diagnostics.filter(d => Math.abs(d.studentResid) > 2).map(d => d.study),
            influential: diagnostics.filter(d => d.influential).map(d => d.study)
        };
    }

    /**
     * Comprehensive sensitivity analysis combining multiple methods
     */
    function sensitivityAnalysis(effects, variances, options = {}) {
    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            leaveOneOut: leaveOneOut(effects, variances, options),
            influence: influenceDiagnostics(effects, variances, options),
            cumulative: options.years ?
                cumulativeMetaAnalysis(effects, variances,
                    [...Array(effects.length).keys()].sort((a, b) => options.years[a] - options.years[b]),
                    options) : null,
            methodComparison: compareEstimators(effects, variances)
        };
    }

    // ============================================
    // GOSH Analysis (Graphical Display of Study Heterogeneity)
    // Reference: Olkin I, Dahabreh IJ, Trikalinos TA. (2012). GOSH - a graphical
    // display of study heterogeneity. Research Synthesis Methods, 3(3), 214-223.
    // ============================================

    /**
     * GOSH Analysis - explores heterogeneity across all subset combinations
     * @param {Array} effects - Effect sizes
     * @param {Array} variances - Variances
     * @param {Object} options - Analysis options
     * @returns {Object} GOSH results with subset statistics
     */
    function goshAnalysis(effects, variances, options = {}) {
        const k = effects.length;
        const method = options.method || 'DL';
        const maxSubsets = options.maxSubsets || 10000;
        const minK = options.minK || 2;

        // For small k, enumerate all subsets; for large k, sample
        const nSubsets = Math.pow(2, k) - 1;
        const useSampling = nSubsets > maxSubsets;

        const results = [];
        let subsetCount = 0;

        if (!useSampling && k <= 15) {
            // Enumerate all subsets of size >= minK
            for (let mask = 1; mask < (1 << k); mask++) {
                const indices = [];
                for (let i = 0; i < k; i++) {
                    if (mask & (1 << i)) indices.push(i);
                }

                if (indices.length >= minK) {
                    const subEffects = indices.map(i => effects[i]);
                    const subVariances = indices.map(i => variances[i]);

                    const result = randomEffects(subEffects, subVariances, method);
                    results.push({
                        indices: indices,
                        k: indices.length,
                        estimate: result.estimate,
                        I2: result.I2,
                        tau2: result.tau2,
                        Q: result.Q
                    });
                    subsetCount++;
                }
            }
        } else {
            // Random sampling for large k
            const seen = new Set();
            while (subsetCount < maxSubsets) {
                // Random subset of size between minK and k
                const size = minK + Math.floor(Math.random() * (k - minK + 1));
                const indices = [];
                const available = [...Array(k).keys()];

                for (let i = 0; i < size; i++) {
                    const idx = Math.floor(Math.random() * available.length);
                    indices.push(available[idx]);
                    available.splice(idx, 1);
                }
                indices.sort((a, b) => a - b);

                const key = indices.join(',');
                if (seen.has(key)) continue;
                seen.add(key);

                const subEffects = indices.map(i => effects[i]);
                const subVariances = indices.map(i => variances[i]);

                const result = randomEffects(subEffects, subVariances, method);
                results.push({
                    indices: indices,
                    k: indices.length,
                    estimate: result.estimate,
                    I2: result.I2,
                    tau2: result.tau2,
                    Q: result.Q
                });
                subsetCount++;
            }
        }

        // Summary statistics
        const estimates = results.map(r => r.estimate);
        const I2s = results.map(r => r.I2);

        // Identify clusters (potential outlier patterns)
        const clusters = identifyGOSHClusters(results);

        // Find influential subsets
        const fullResult = randomEffects(effects, variances, method);
        const influential = results.filter(r =>
            Math.abs(r.estimate - fullResult.estimate) > 2 * fullResult.se ||
            Math.abs(r.I2 - fullResult.I2) > 25
        );

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            subsets: results,
            nSubsets: subsetCount,
            method: useSampling ? 'random' : 'exhaustive',
            summary: {
                estimate: {
                    mean: Stats.mean(estimates),
                    sd: Stats.sd(estimates),
                    min: Math.min(...estimates),
                    max: Math.max(...estimates)
                },
                I2: {
                    mean: Stats.mean(I2s),
                    sd: Stats.sd(I2s),
                    min: Math.min(...I2s),
                    max: Math.max(...I2s)
                }
            },
            clusters: clusters,
            influential: influential,
            fullAnalysis: fullResult,
            plotData: {
                x: estimates,
                y: I2s,
                k: results.map(r => r.k)
            }
        };
    }

    /**
     * Identify clusters in GOSH plot using simple k-means-like approach
     */
    function identifyGOSHClusters(results, nClusters = 3) {
        if (results.length < nClusters) return [];

        // Simple clustering based on estimate and I2
        const points = results.map(r => ({ x: r.estimate, y: r.I2 / 100 }));

        // Initialize centroids
        const centroids = [];
        const step = Math.floor(results.length / nClusters);
        for (let i = 0; i < nClusters; i++) {
            centroids.push({ ...points[i * step] });
        }

        // K-means iterations
        for (let iter = 0; iter < 20; iter++) {
            // Assign points to clusters
            const clusters = Array(nClusters).fill(null).map(() => []);
            points.forEach((p, i) => {
                let minDist = Infinity;
                let cluster = 0;
                centroids.forEach((c, j) => {
                    const dist = Math.sqrt(Math.pow(p.x - c.x, 2) + Math.pow(p.y - c.y, 2));
                    if (dist < minDist) {
                        minDist = dist;
                        cluster = j;
                    }
                });
                clusters[cluster].push(i);
            });

            // Update centroids
            centroids.forEach((c, j) => {
                if (clusters[j].length > 0) {
                    c.x = Stats.mean(clusters[j].map(i => points[i].x));
                    c.y = Stats.mean(clusters[j].map(i => points[i].y));
                }
            });
        }

        return centroids.map((c, i) => ({
            centroid: { estimate: c.x, I2: c.y * 100 },
            size: results.filter((_, j) => {
                const p = points[j];
                let minDist = Infinity;
                let cluster = 0;
                centroids.forEach((cent, k) => {
                    const dist = Math.sqrt(Math.pow(p.x - cent.x, 2) + Math.pow(p.y - cent.y, 2));
                    if (dist < minDist) {
                        minDist = dist;
                        cluster = k;
                    }
                });
                return cluster === i;
            }).length
        }));
    }

    // ============================================
    // Bootstrap Confidence Intervals
    // Reference: Adams DC, Gurevitch J, Rosenberg MS. (1997). Resampling tests
    // for meta-analysis of ecological data. Ecology, 78(4), 1277-1283.
    // ============================================

    /**
     * Bootstrap confidence intervals for meta-analysis
     * @param {Array} effects - Effect sizes
     * @param {Array} variances - Variances
     * @param {Object} options - Bootstrap options
     * @returns {Object} Bootstrap results with CIs
     */
    function bootstrapCI(effects, variances, options = {}) {
        const nBoot = options.nBoot || 10000;
        const alpha = options.alpha || 0.05;
        const method = options.method || 'DL';
        const type = options.type || 'percentile';  // percentile, bca, basic

        const k = effects.length;
        const bootEstimates = [];
        const bootTau2 = [];
        const bootI2 = [];

        // Original estimate
        const original = randomEffects(effects, variances, method);

        // Bootstrap resampling
        for (let b = 0; b < nBoot; b++) {
            // Resample with replacement
            const indices = [];
            for (let i = 0; i < k; i++) {
                indices.push(Math.floor(Math.random() * k));
            }

            const bootEffects = indices.map(i => effects[i]);
            const bootVariances = indices.map(i => variances[i]);

            try {
                const result = randomEffects(bootEffects, bootVariances, method);
                if (isFinite(result.estimate)) {
                    bootEstimates.push(result.estimate);
                    bootTau2.push(result.tau2);
                    bootI2.push(result.I2);
                }
            } catch (e) {
                // Skip failed iterations
            }
        }

        // Sort for percentiles
        bootEstimates.sort((a, b) => a - b);
        bootTau2.sort((a, b) => a - b);
        bootI2.sort((a, b) => a - b);

        const nValid = bootEstimates.length;
        const lower = Math.floor(nValid * (alpha / 2));
        const upper = Math.floor(nValid * (1 - alpha / 2));

        let ci, tau2CI, I2CI;

        if (type === 'percentile') {
            ci = [bootEstimates[lower], bootEstimates[upper]];
            tau2CI = [bootTau2[lower], bootTau2[upper]];
            I2CI = [bootI2[lower], bootI2[upper]];
        } else if (type === 'basic') {
            // Basic bootstrap: 2*theta - theta*(1-alpha), 2*theta - theta*(alpha)
            ci = [
                2 * original.estimate - bootEstimates[upper],
                2 * original.estimate - bootEstimates[lower]
            ];
            tau2CI = [
                Math.max(0, 2 * original.tau2 - bootTau2[upper]),
                2 * original.tau2 - bootTau2[lower]
            ];
            I2CI = [
                Math.max(0, 2 * original.I2 - bootI2[upper]),
                Math.min(100, 2 * original.I2 - bootI2[lower])
            ];
        } else if (type === 'bca') {
            // BCa (Bias-Corrected and Accelerated)
            ci = bcaInterval(bootEstimates, original.estimate, effects, variances, method, alpha);
            tau2CI = [bootTau2[lower], bootTau2[upper]];  // Simplified
            I2CI = [bootI2[lower], bootI2[upper]];
        }

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
        // Bootstrap methods
            estimate: original.estimate,
            ci: ci,
            ciMethod: type,
            tau2: {
                estimate: original.tau2,
                ci: tau2CI
            },
            I2: {
                estimate: original.I2,
                ci: I2CI
            },
            nBoot: nBoot,
            nValid: nValid,
            bootDistribution: {
                mean: Stats.mean(bootEstimates),
                sd: Stats.sd(bootEstimates),
                bias: Stats.mean(bootEstimates) - original.estimate
            }
        };
    }

    /**
     * BCa (Bias-Corrected and Accelerated) interval
     */
    function bcaInterval(bootSamples, original, effects, variances, method, alpha) {
        const n = bootSamples.length;
        const k = effects.length;

        // Bias correction factor
        const nLess = bootSamples.filter(b => b < original).length;
        const z0 = Stats.qnorm(nLess / n);

        // Acceleration factor (jackknife)
        const jackknife = [];
        for (let i = 0; i < k; i++) {
            const jackEffects = effects.filter((_, j) => j !== i);
            const jackVariances = variances.filter((_, j) => j !== i);
            if (jackEffects.length >= 2) {
                const result = randomEffects(jackEffects, jackVariances, method);
                jackknife.push(result.estimate);
            }
        }

        const jackMean = Stats.mean(jackknife);
        const num = jackknife.reduce((s, j) => s + Math.pow(jackMean - j, 3), 0);
        const den = jackknife.reduce((s, j) => s + Math.pow(jackMean - j, 2), 0);
        const a = den > 0 ? num / (6 * Math.pow(den, 1.5)) : 0;

        // Adjusted percentiles
        const zAlpha = Stats.qnorm(alpha / 2);
        const zAlphaUpper = Stats.qnorm(1 - alpha / 2);

        const adjLower = Stats.pnorm(z0 + (z0 + zAlpha) / (1 - a * (z0 + zAlpha)));
        const adjUpper = Stats.pnorm(z0 + (z0 + zAlphaUpper) / (1 - a * (z0 + zAlphaUpper)));

        const lowerIdx = Math.max(0, Math.floor(n * adjLower));
        const upperIdx = Math.min(n - 1, Math.floor(n * adjUpper));

        return [bootSamples[lowerIdx], bootSamples[upperIdx]];
    }

    /**
     * Parametric bootstrap (resampling from estimated distribution)
     */
    function parametricBootstrapCI(effects, variances, options = {}) {
        const nBoot = options.nBoot || 10000;
        const alpha = options.alpha || 0.05;
        const method = options.method || 'DL';

        // Original estimates
        const original = randomEffects(effects, variances, method);
        const mu = original.estimate;
        const tau2 = original.tau2;

        const bootEstimates = [];
        const k = effects.length;

        for (let b = 0; b < nBoot; b++) {
            // Generate new effect sizes from estimated distribution
            const newEffects = [];
            for (let i = 0; i < k; i++) {
                // True effect from N(mu, tau2), observed from N(true, vi)
                const trueEffect = mu + Math.sqrt(tau2) * Stats.rnorm();
                const observed = trueEffect + Math.sqrt(variances[i]) * Stats.rnorm();
                newEffects.push(observed);
            }

            const result = randomEffects(newEffects, variances, method);
            if (isFinite(result.estimate)) {
                bootEstimates.push(result.estimate);
            }
        }

        bootEstimates.sort((a, b) => a - b);
        const lower = Math.floor(bootEstimates.length * (alpha / 2));
        const upper = Math.floor(bootEstimates.length * (1 - alpha / 2));

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
        // Bootstrap methods
            estimate: mu,
            ci: [bootEstimates[lower], bootEstimates[upper]],
            type: 'parametric',
            nBoot: bootEstimates.length
        };
    }


    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
