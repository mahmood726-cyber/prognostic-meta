        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
            subgroups: results,
            QBetween,
            dfBetween,
            pBetween,
            heterogeneityBetween: pBetween < 0.1 ?
                'Significant difference between subgroups' :
                'No significant difference between subgroups'
        };
    }

    /**
     * Mixed-effects meta-regression
     * Reference: Thompson SG, Higgins JPT. (2002). How should meta-regression
     * analyses be undertaken and interpreted? Statistics in Medicine, 21(11), 1559-1573.
     *
     * Also: Hedges LV, Pigott TD. (2004). The power of statistical tests for
     * moderators in meta-analysis. Psychological Methods, 9(4), 426-445.
     */
    function metaRegression(effects, variances, moderators, method = 'REML', knha = false) {
        const k = effects.length;
        const p = moderators[0].length;  // Number of moderators

        // Add intercept
        const X = moderators.map(row => [1, ...row]);

        // Initial tau² estimate
        let tau2 = tau2DL(effects, variances);

        // Iterate for REML
        for (let iter = 0; iter < 100; iter++) {
            const W = variances.map(v => 1 / (v + tau2));
            const WMatrix = W.map(w => [w]);

            // Weighted least squares
            // β = (X'WX)^(-1) X'Wy
            const XtW = Stats.transpose(X).map((row, i) =>
                row.map((val, j) => val * W[j])
            );
            const XtWX = Stats.matmul(XtW, X);
            const XtWy = XtW.map(row =>
                row.reduce((sum, val, j) => sum + val * effects[j], 0)
            );

            const XtWXinv = Stats.inverse(XtWX);
            const beta = XtWXinv.map(row =>
                row.reduce((sum, val, j) => sum + val * XtWy[j], 0)
            );

            // Residuals
            const fitted = X.map(row =>
                row.reduce((sum, val, j) => sum + val * beta[j], 0)
            );
            const residuals = effects.map((y, i) => y - fitted[i]);

            // Update tau² (REML)
            if (method === 'REML') {
                const QE = residuals.reduce((sum, r, i) => sum + W[i] * r * r, 0);
                const sumW = Stats.sum(W);
                const trWX = XtWX.reduce((sum, row, i) => sum + row.reduce((s, v) => s + v, 0) / (p + 1), 0);

                const tau2New = Math.max(0, (QE - (k - p - 1)) / (sumW - trWX));

                if (Math.abs(tau2New - tau2) < 1e-6) {
                    tau2 = tau2New;
                    break;
                }
                tau2 = tau2New;
            } else {
                break;
            }
        }

        // Final estimates
        const W = variances.map(v => 1 / (v + tau2));
        const XtW = Stats.transpose(X).map((row, i) =>
            row.map((val, j) => val * W[j])
        );
        const XtWX = Stats.matmul(XtW, X);
        const XtWy = XtW.map(row =>
            row.reduce((sum, val, j) => sum + val * effects[j], 0)
        );

        const XtWXinv = Stats.inverse(XtWX);
        const beta = XtWXinv.map(row =>
            row.reduce((sum, val, j) => sum + val * XtWy[j], 0)
        );

        // Standard errors
        const seBeta = XtWXinv.map((row, i) => Math.sqrt(row[i]));

        // Fitted and residuals
        const fitted = X.map(row =>
            row.reduce((sum, val, j) => sum + val * beta[j], 0)
        );
        const residuals = effects.map((y, i) => y - fitted[i]);

        // Test of moderators (QM)
        const QE = residuals.reduce((sum, r, i) => sum + W[i] * r * r, 0);
        const QM = effects.reduce((sum, y, i) => sum + W[i] * y * y, 0) -
                   Math.pow(effects.reduce((sum, y, i) => sum + W[i] * y, 0), 2) / Stats.sum(W) -
                   QE;

        const dfM = p;
        const pQM = 1 - Stats.pchisq(QM, dfM);

        // HKSJ adjustment for meta-regression
        // Reference: Knapp G, Hartung J. (2003). Improved tests for a random
        // effects meta-regression with a single covariate.
        // Statistics in Medicine, 22(17), 2693-2710.
        let adjustedSE = seBeta;
        if (knha) {
            const qStar = QE / (k - p - 1);
            adjustedSE = seBeta.map(se => se * Math.sqrt(Math.max(1, qStar)));
        }

        // Coefficient tests
        const coefficients = beta.map((b, i) => {
            const se = adjustedSE[i];
            const zOrT = b / se;
            const df = knha ? k - p - 1 : Infinity;
            const pVal = knha ?
                2 * (1 - Stats.pt(Math.abs(zOrT), df)) :
                2 * (1 - Stats.pnorm(Math.abs(zOrT)));
            const critVal = knha ? Stats.qt(0.975, df) : 1.96;

        
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
            estimate: thetaHC,
            se: seRobust,
            ci: {
                lower: thetaHC - tCrit * seRobust,
                upper: thetaHC + tCrit * seRobust
            },
            tau2: tau2HC,
            method: 'Henmi-Copas (2010)',
            robustToPublicationBias: true
        };
    }


    return {
                estimate: b,
                se,
                statistic: zOrT,
                pValue: pVal,
                ci: {
                    lower: b - critVal * se,
                    upper: b + critVal * se
                }
            };
        });

        // R² analog
        const tau2Null = tau2DL(effects, variances);
        const R2 = tau2Null > 0 ? 1 - tau2 / tau2Null : 0;

        // I² residual
        const I2Res = calculateHeterogeneity(residuals, variances, tau2).I2;

    
    /**
     * Calculate confidence interval using appropriate distribution
     * Uses t-distribution when k < 10, z-distribution otherwise
     * Reference: Hartung J, Knapp G. (2001). Statistics in Medicine.
     */
    function calculateCI(effect, se, k, alpha = 0.05) {
        // Use t-distribution for small samples (k < 10)
        const useT = k < 10;
        const df = Math.max(1, k - 1);

        let critical;
        if (useT) {
            critical = Stats.qt(1 - alpha/2, df);
        } else {
            critical = Stats.qnorm(1 - alpha/2);
        }

        return {
            lower: effect - critical * se,
            upper: effect + critical * se,
            method: useT ? `t-distribution (df=${df})` : 'z-distribution',
            critical: critical
        };
    }

    /**
     * Henmi-Copas confidence interval
     * Robust to publication bias
     * Reference: Henmi M, Copas JB. (2010). Statistics in Medicine, 29(29), 2969-2983.
     */
    function henmiCopasCI(effects, variances, alpha = 0.05) {
        const k = effects.length;
        const weights = variances.map(v => 1 / v);
        const sumW = Stats.sum(weights);

        // Fixed effect estimate
        const thetaFE = effects.reduce((s, y, i) => s + weights[i] * y, 0) / sumW;

        // Calculate Q statistic
        const Q = effects.reduce((s, y, i) => s + weights[i] * Math.pow(y - thetaFE, 2), 0);

        // Henmi-Copas adjustment
        // Accounts for potential publication bias in CI width
        const c = sumW - Stats.sum(weights.map(w => w * w)) / sumW;
        const tau2HC = Math.max(0, (Q - (k - 1)) / c);

        // Adjusted weights
        const wHC = variances.map(v => 1 / (v + tau2HC));
        const sumWHC = Stats.sum(wHC);
        const thetaHC = effects.reduce((s, y, i) => s + wHC[i] * y, 0) / sumWHC;

        // Variance with robust adjustment
        const seHC = Math.sqrt(1 / sumWHC);

        // Additional variance component for publication bias uncertainty
        const V_extra = tau2HC > 0 ? tau2HC / k : 0;
        const seRobust = Math.sqrt(1 / sumWHC + V_extra);

        const tCrit = Stats.qt(1 - alpha/2, k - 1);

        return {
