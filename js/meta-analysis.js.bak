        // Heterogeneity statistics
        const hetStats = calculateHeterogeneity(effects, variances, tau2);

        // Combine warnings
        const allWarnings = [
            ...validation.warnings,
            ...(hetStats.warnings || []),
            ...(convergenceInfo.convergenceWarning ? [convergenceInfo.convergenceWarning] : [])
